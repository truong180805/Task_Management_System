// prisma/schema.prisma

// 1. Client Generator
generator client {
  provider = "prisma-client-js"
}

// 2. Database Connection
datasource db {
  provider = "postgresql"
}

// 3. Enums (Danh sách các giá trị cố định)
enum ActiveMode {
  work
  personal
  chill
}

enum TaskStatus {
  todo
  in_progress
  done
  archived
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

// 4. Models (Các bảng trong Database)

model User {
  id            String      @id @default(uuid()) @map("user_id")
  email         String      @unique @db.VarChar(255)
  passwordHash  String      @map("password_hash") @db.Text
  fullName      String?     @map("full_name") @db.VarChar(200)
  avatarUrl     String?     @map("avatar_url") @db.Text
  activeMode    ActiveMode  @default(work) @map("active_mode")
  timezone      String?     @db.VarChar(50)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relationships (Liên kết dữ liệu)
  workspaces    Workspace[]
  tasks         Task[]

  @@map("users") // Đổi tên bảng trong PostgreSQL thành 'users'
}

model Workspace {
  id          String     @id @default(uuid()) @map("workspace_id")
  userId      String     @map("user_id")
  name        String     @db.VarChar(200)
  icon        String?    @db.VarChar(50)
  description String?    @db.Text
  modeType    ActiveMode @map("mode_type")
  isFavorite  Boolean    @default(false) @map("is_favorite")
  createdAt   DateTime   @default(now()) @map("created_at")

  // Relationships
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workspaces")
}

model Task {
  id            String       @id @default(uuid()) @map("task_id")
  userId        String       @map("user_id")
  parentId      String?      @map("parent_id")
  title         String       @db.VarChar(500)
  status        TaskStatus   @default(todo)
  priority      TaskPriority @default(medium)
  dueDate       DateTime?    @map("due_date")
  estimatedMins Int?         @map("estimated_mins")
  aiGenerated   Boolean      @default(false) @map("ai_generated")

  // Relationships
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Task?        @relation("TaskToTask", fields: [parentId], references: [id])
  subtasks      Task[]       @relation("TaskToTask")

  @@map("tasks")
}